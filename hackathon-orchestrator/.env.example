# Models via OpenRouter (used by OpenAI Agents SDK Planner/Fixer/Reviewer)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model slugs (OpenRouter naming)
ORCH_PLANNER_MODEL=anthropic/claude-sonnet-4
ORCH_FIXER_MODEL=anthropic/claude-sonnet-4
ORCH_REVIEWER_MODEL=openai/gpt-4o-mini

# Cursor CLI (coding agent)
CURSOR_API_KEY=cursor-xxxxxxxxxxxxxxxxxxxxxxxx
ORCH_CURSOR_BIN=cursor-agent
ORCH_CURSOR_TIMEOUT_S=600

# GitHub (gh CLI must be already authenticated: `gh auth status`)
ORCH_GH_REPO=owner/repo
ORCH_ISSUE_LABEL=agent-ready
ORCH_BASE_BRANCH=main

# Runtime
ORCH_MAX_REPAIR_ATTEMPTS=2
ORCH_RUN_LOG_DIR=./runs
ORCH_WORKTREES_DIR=./.worktrees
